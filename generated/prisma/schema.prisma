// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum EducationField {
  BUILDING // Bygg
  CONSTRUCTION // Annlegg
}

enum Status {
  NEW
  IN_PROGRESS
  COMPLETE
}

enum OrderStatus {
  NEW
  IN_CONTACT
  COMPLETED
}

model Product {
  id              Int             @id @default(autoincrement())
  educationField  EducationField?
  title           String
  description     String
  price           Decimal
  measures        Json?
  amount          Int
  publishedAt     DateTime        @default(now())
  images          ProductImage[]
  contactPersonId Int?
  contactPerson   ContactPerson?  @relation(fields: [contactPersonId], references: [id])
  orders          ProductOrder[]

  @@index([educationField])
}

model ProductImage {
  id        String  @id
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  sortOrder Int     @default(0)
}

model ProjectRequest {
  id                 Int             @id @default(autoincrement())
  educationField     EducationField?
  title              String
  description        String
  minPrice           Decimal
  maxPrice           Decimal
  clientForename     String
  clientSurname      String
  clientEmail        String
  clientPhone        String
  organizationName   String?
  organizationNumber String?
  address            String
  billingAddress     String
  status             Status          @default(NEW)
  createdAt          DateTime        @default(now())

  @@index([clientEmail])
  @@index([clientPhone])
  @@index([organizationNumber])
}

model ClientReview {
  id        Int      @id @default(autoincrement())
  name      String
  role      String?
  orgName   String?
  orgURL    String?
  imageId   String?
  message   String
  createdAt DateTime @default(now())
}

model ContactPerson {
  id      Int       @id @default(autoincrement())
  name    String
  email   String
  phone   String
  title   String
  product Product[]
}

model ProductOrder {
  id           Int         @id @default(autoincrement())
  clientName   String
  clientEmail  String
  clientPhone  String
  amount       Int
  extraDetails String?
  status       OrderStatus @default(NEW)
  productId    Int?
  product      Product?    @relation(fields: [productId], references: [id])
}
