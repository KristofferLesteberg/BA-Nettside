// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Catorgory {
  id Int @id @default(autoincrement())
  name String
  products Product[]
}

model Product {
  id Int @id @default(autoincrement())
  title String
  description String
  specs String
  price Float
  producer String
  className String
  amount Int
  catogoryId Int
  catorgory Catorgory @relation(fields: [catogoryId], references: [id])
}

model Request {
  id Int @id @default(autoincrement())
  title String 
  }
