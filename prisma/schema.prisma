  title String
  description String
  price Decimal
  measures Json?
  amount Int
  publishedAt DateTime @default(now())
  images         ProductImage[]

  @@index ([educationField])
}

model ProductImage {
  id        String   @id
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  sortOrder Int      @default(0)
}

